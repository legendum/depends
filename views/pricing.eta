    margin: 1rem 0 0.75rem;
  }

  .pricing-table th, .pricing-table td {
    padding: 0.5rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }

  .pricing-table th:last-child, .pricing-table td:last-child {
    text-align: right;
  }

  .pricing-table th {
    font-weight: 600;
